{
  "version": 1,
  "github": {
    "owner": "zhangweis",
    "repo": "chrome-extensions",
    "prepareLabels": "create-missing",
    "labels": {
      "auto": {
        "name": "agent:auto",
        "color": "0E8A16",
        "description": "Scoped autonomous Codex implementation"
      },
      "planAuto": {
        "name": "agent:plan-auto",
        "color": "5319E7",
        "description": "Autonomous Codex planning and issue-tree execution"
      },
      "running": {
        "name": "agent:running",
        "color": "1D76DB",
        "description": "Codex orchestration is currently running"
      },
      "blocked": {
        "name": "agent:blocked",
        "color": "B60205",
        "description": "Codex orchestration is blocked and needs maintainer input"
      },
      "manual": {
        "name": "agent:manual",
        "color": "BFDADC",
        "description": "Issue is reserved for manual work"
      },
      "review": {
        "name": "agent:review",
        "color": "FBCA04",
        "description": "Codex work is ready for human review"
      },
      "child": {
        "name": "agent:child",
        "color": "C2E0C6",
        "description": "Child issue owned by an autonomous parent issue tree"
      }
    }
  },
  "runner": {
    "workspaceRoot": ".codex-orchestrator/workspaces",
    "maxParallelChildren": 3,
    "maxParallelScopedIssues": 3,
    "stateDir": ".codex-orchestrator/state",
    "allowAgentLocalCommits": false,
    "worktreeCleanup": {
      "enabled": true
    }
  },
  "codex": {
    "adapter": "codex-cli",
    "command": "/usr/local/bin/codex",
    "args": [
      "exec",
      "--cd",
      "${worktreePath}",
      "--sandbox",
      "workspace-write",
      "--add-dir",
      "${stateDir}",
      "-c",
      "sandbox_workspace_write.network_access=true",
      "--output-last-message",
      "${reportPath}",
      "-"
    ],
    "timeoutMs": 1800000,
    "mobileTimeoutMs": 3600000,
    "idleTimeoutMs": 300000,
    "profiles": {},
    "promptFileEnv": "CODEX_ORCHESTRATOR_PROMPT_FILE",
    "reportFileEnv": "CODEX_ORCHESTRATOR_REPORT_FILE"
  },
  "project": {
    "configDir": ".codex-orchestrator",
    "promptsDir": ".codex-orchestrator/prompts"
  },
  "workflows": {
    "prd": {
      "skillName": "to-prd",
      "source": "package-bundled-prompt",
      "promptPath": ".codex-orchestrator/prompts/workflows/prd.md"
    },
    "issueBreakdown": {
      "skillName": "to-issues",
      "source": "package-bundled-prompt",
      "promptPath": ".codex-orchestrator/prompts/workflows/issue-breakdown.md"
    },
    "breakdownReview": {
      "skillName": "issue-breakdown-review",
      "source": "package-bundled-prompt",
      "promptPath": ".codex-orchestrator/prompts/workflows/breakdown-review.md"
    },
    "triage": {
      "skillName": "triage",
      "source": "package-bundled-prompt",
      "promptPath": ".codex-orchestrator/prompts/workflows/triage.md"
    },
    "scopedImplementation": {
      "skillName": "spec-implementer",
      "source": "package-bundled-prompt",
      "promptPath": ".codex-orchestrator/prompts/workflows/scoped-implementation.md"
    },
    "issueTreeOrchestration": {
      "skillName": "issue-orchestrator",
      "source": "package-bundled-prompt",
      "promptPath": ".codex-orchestrator/prompts/workflows/issue-tree-orchestration.md"
    },
    "acceptanceProof": {
      "skillName": "spec-implementer",
      "source": "package-bundled-prompt",
      "promptPath": ".codex-orchestrator/prompts/workflows/acceptance-proof.md"
    }
  },
  "checks": {
    "test": "deno task test"
  },
  "checksPolicy": {
    "missingNpmScript": "skip",
    "lintBaseline": {
      "mode": "strict"
    }
  },
  "reviewGates": {
    "acceptanceProof": {
      "enabled": true,
      "artifactDir": ".codex-orchestrator/proofs",
      "issueTextPatterns": [
        "\\bUI\\b",
        "frontend",
        "responsive",
        "layout",
        "visual",
        "screenshot",
        "acceptance",
        "proof",
        "smoke",
        "\\bAPI\\b",
        "worker",
        "\\bCLI\\b",
        "скриншот",
        "скріншот",
        "viewport",
        "dark theme",
        "мобіл",
        "mobile"
      ],
      "changedPathGlobs": [
        "src/frontend/**",
        "frontend/**",
        "app/**",
        "pages/**",
        "components/**"
      ],
      "proofOwnedPathGlobs": [
        ".codex-orchestrator/proofs/**"
      ],
      "runnerValidationCommand": "deno run -A npm:codex-orchestrator visual-proof auto --issue ${issueNumber} --target .",
      "runnerTimeoutMs": 900000,
      "envPassthrough": [],
      "browserProof": {
        "strictConsoleErrors": false,
        "strictNetworkFailures": false
      },
      "maxIterations": 5
    },
    "visualProof": {
      "enabled": true,
      "artifactDir": ".codex-orchestrator/proofs",
      "issueTextPatterns": [
        "\\bUI\\b",
        "frontend",
        "responsive",
        "layout",
        "visual",
        "screenshot",
        "скриншот",
        "скріншот",
        "viewport",
        "dark theme",
        "мобіл",
        "mobile"
      ],
      "changedPathGlobs": [
        "src/frontend/**",
        "frontend/**",
        "app/**",
        "pages/**",
        "components/**"
      ],
      "requiredValidationPatterns": [
        "Playwright",
        "screenshot",
        "visual",
        "viewport",
        "runner visual proof"
      ],
      "blockOnSkippedPatterns": [
        "Playwright",
        "screenshot",
        "visual",
        "viewport",
        "runner visual proof"
      ],
      "minScreenshotArtifacts": 1,
      "requireWhenDesirable": false,
      "runnerValidationCommand": "deno run -A npm:codex-orchestrator visual-proof auto --issue ${issueNumber} --target .",
      "runnerTimeoutMs": 900000,
      "envPassthrough": []
    },
    "quality": {
      "enabled": true,
      "runtimeChangedPathGlobs": [
        "src/**",
        "app/**",
        "pages/**",
        "components/**",
        "lib/**",
        "packages/**",
        "*.js",
        "*.jsx",
        "*.ts",
        "*.tsx",
        "*.mjs",
        "*.cjs"
      ],
      "testChangedPathGlobs": [
        "test/**",
        "tests/**",
        "__tests__/**",
        "*.test.*",
        "*.spec.*",
        "src/**/*.test.*",
        "src/**/*.spec.*"
      ],
      "tdd": {
        "enabled": true,
        "requireTestChange": true,
        "requiredValidationPatterns": [
          "red.*green",
          "fail(?:ed|ing)?.*pass(?:ed|ing)?",
          "test.*fail(?:ed|ing)?.*test.*pass(?:ed|ing)?"
        ]
      },
      "cleanupReview": {
        "enabled": true,
        "runtimeFileThreshold": 3,
        "requiredValidationPatterns": [
          "\\$?cleanup-review",
          "cleanup review"
        ]
      },
      "codeReview": {
        "enabled": true,
        "requiredValidationPatterns": [
          "\\$?code-review",
          "code review"
        ]
      }
    }
  },
  "loopPolicy": {
    "issueSelection": {
      "priorityLabels": [
        "priority:critical",
        "priority:high",
        "priority:medium",
        "priority:low"
      ],
      "tieBreaker": "issue-number-asc"
    },
    "rework": {
      "maxAttempts": 1,
      "retryableBlockers": [
        "missing-completion-report",
        "invalid-completion-report",
        "no-changed-files",
        "failed-configured-checks",
        "missing-quality-gate-evidence",
        "failed-acceptance-proof"
      ]
    },
    "freshContextReview": {
      "enabled": false,
      "mode": "advisory",
      "blockOnHighConfidencePolicyViolations": true
    },
    "durableRunSummaries": {
      "enabled": true
    },
    "policySuggestions": {
      "enabled": true,
      "maxSuggestions": 5
    }
  },
  "deny": {
    "secretFiles": [
      ".env",
      ".env.*"
    ],
    "destructiveDbOrCache": true,
    "productionDeployOrRelease": true,
    "additionalPathGlobs": []
  },
  "branches": {
    "base": {
      "mode": "explicit",
      "remote": "origin",
      "branch": "main"
    },
    "scopedIssue": "codex/issue-${issueNumber}",
    "issueTree": "codex/tree-${parentIssueNumber}"
  },
  "pullRequests": {
    "scopedIssueTitle": "Codex: issue #${issueNumber}",
    "issueTreeTitle": "Codex: parent issue #${parentIssueNumber}"
  },
  "issueClassification": {
    "promotionCriteria": [
      "api-contract",
      "dto-or-schema",
      "persistence",
      "auth-or-permissions",
      "billing",
      "background-job",
      "shared-state",
      "multi-service",
      "three-or-more-runtime-files"
    ],
    "clarificationGate": "block-and-comment"
  }
}
